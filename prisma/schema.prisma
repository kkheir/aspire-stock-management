generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum StockStatus {
  in_stock
  low_stock
  ordered
  discontinued
}

model InventoryItem {
  id           String      @id @default(cuid())
  name         String
  sku          String      @unique
  quantity     Int
  category     String
  status       StockStatus @default(in_stock)
  reorderLevel Int         @default(5)
  location     String      @default("")
  supplier     String      @default("")
  notes        String      @default("")
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt

  @@index([name])
  @@index([category])
  @@index([status])
}
